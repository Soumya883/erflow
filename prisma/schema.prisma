generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

model User {
  id           String @id @default(cuid())
  name         String
  email        String @unique
  passwordHash String
  role         Role   @default(EMPLOYEE)

  employeeProfile EmployeeProfile?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model EmployeeProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  jobTitle  String?
  salary    Float?         @default(0)
  phone     String?
  joinDate  DateTime?      @db.Date
  avatarUrl String?
  status    EmployeeStatus @default(ACTIVE)

  // Bank Details
  bankName          String?
  bankBranch        String?
  bankAccountNumber String?
  bankIfscCode      String?

  tasks          Task[]
  leaveRequests  LeaveRequest[]
  attendanceLogs AttendanceLog[]
  documents      Document[]
  announcements  Announcement[]    @relation("Author")
  spreadsheets   Spreadsheet[]
  chatRooms      ChatParticipant[]
  chatMessages   ChatMessage[]
  assetAssignments AssetAssignment[]
  goals          Goal[]
  performanceReviews PerformanceReview[] @relation("Reviewee")
  reviewsGiven       PerformanceReview[] @relation("Reviewer")
  expenses           Expense[]
  ticketsCreated     Ticket[] @relation("TicketAuthor")
  ticketsAssigned    Ticket[] @relation("TicketAssignee")

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model Department {
  id   String @id @default(cuid())
  name String @unique

  employees EmployeeProfile[]
  jobPostings JobPosting[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(PLANNING)

  tasks Task[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?    @db.Text
  status      TaskStatus @default(TODO)
  priority    String     @default("MEDIUM") // LOW, MEDIUM, HIGH
  dueDate     DateTime?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  assigneeId String?
  assignee   EmployeeProfile? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model LeaveRequest {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type      String // e.g. SICK, VACATION, PERSONAL
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  status    LeaveStatus @default(PENDING)
  reason    String?     @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model AttendanceLog {
  id         String          @id @default(cuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date     DateTime  @db.Date
  checkIn  DateTime? @db.Timestamptz(3)
  checkOut DateTime? @db.Timestamptz(3)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([employeeId, date])
}

model Announcement {
  id      String @id @default(cuid())
  title   String
  content String @db.Text

  authorId String
  author   EmployeeProfile @relation("Author", fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model Document {
  id      String @id @default(cuid())
  name    String
  fileUrl String

  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  uploadedById String

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model AuditLog {
  id       String  @id @default(cuid())
  action   String // e.g. CREATE, UPDATE, DELETE
  entity   String // e.g. USER, LEAVE_REQUEST
  entityId String
  userId   String // The user who performed the action
  details  String? @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(3)
}

model SystemSettings {
  id                String  @id @default(cuid())
  companyName       String  @default("OfficeFlow")
  logoUrl           String?
  primaryColor      String  @default("#4F46E5") // Indigo-600
  workingHoursStart String  @default("09:00")
  workingHoursEnd   String  @default("17:00")

  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model Spreadsheet {
  id    String @id @default(cuid())
  title String
  data  Json // Stores the fortune-sheet JSON data

  authorId String
  author   EmployeeProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model ChatRoom {
  id      String  @id @default(cuid())
  isGroup Boolean @default(false)
  name    String? // Null for 1-on-1 chats

  participants ChatParticipant[]
  messages     ChatMessage[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model ChatParticipant {
  id String @id @default(cuid())

  roomId String
  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now()) @db.Timestamptz(3)

  @@unique([roomId, employeeId])
}

model ChatMessage {
  id      String @id @default(cuid())
  content String @db.Text

  roomId String
  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  authorId String
  author   EmployeeProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

enum AssetCategory {
  LAPTOP
  FURNITURE
  PERIPHERAL
  SOFTWARE
  OTHER
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

model Asset {
  id           String        @id @default(cuid())
  name         String
  description  String?       @db.Text
  serialNumber String?
  category     AssetCategory @default(OTHER)
  status       AssetStatus   @default(AVAILABLE)
  purchaseDate DateTime?     @db.Date
  value        Float?        @default(0)

  assignments  AssetAssignment[]

  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)
}

model AssetAssignment {
  id         String          @id @default(cuid())
  
  assetId    String
  asset      Asset           @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  assignedDate       DateTime  @db.Date
  expectedReturnDate DateTime? @db.Date
  returnedDate       DateTime? @db.Date
  notes              String?   @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

enum GoalStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ApplicantStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFERED
  HIRED
  REJECTED
}

model Goal {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  progress    Int        @default(0)
  status      GoalStatus @default(PENDING)
  dueDate     DateTime?  @db.Date
  
  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model PerformanceReview {
  id           String @id @default(cuid())
  reviewPeriod String // e.g., "Q1 2026", "Annual 2026"
  rating       Int    // 1 to 5
  comments     String @db.Text

  employeeId   String
  employee     EmployeeProfile @relation("Reviewee", fields: [employeeId], references: [id], onDelete: Cascade)

  reviewerId   String
  reviewer     EmployeeProfile @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model JobPosting {
  id          String   @id @default(cuid())
  title       String
  location    String
  type        String   // e.g., "Full-time", "Contract"
  description String   @db.Text
  isActive    Boolean  @default(true)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  applicants   Applicant[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

model Applicant {
  id        String          @id @default(cuid())
  name      String
  email     String
  phone     String?
  resumeUrl String?
  status    ApplicantStatus @default(APPLIED)
  notes     String?         @db.Text

  jobId     String
  job       JobPosting @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

// ========================
// CRM & CLIENT MANAGEMENT
// ========================

model Client {
  id        String   @id @default(cuid())
  name      String
  company   String
  email     String
  phone     String?
  address   String?  @db.Text
  
  invoices  Invoice[]

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  company   String
  email     String
  phone     String?
  value     Float?     // Estimated deal value
  status    LeadStatus @default(NEW)
  notes     String?    @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

// ========================
// FINANCE & ACCOUNTING
// ========================

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model Expense {
  id          String        @id @default(cuid())
  title       String
  amount      Float
  category    String        // e.g., Travel, Supplies, Software
  date        DateTime      @db.Date
  receiptUrl  String?
  status      ExpenseStatus @default(PENDING)
  notes       String?       @db.Text

  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id          String        @id @default(cuid())
  invoiceNo   String        @unique
  amount      Float
  issueDate   DateTime      @db.Date
  dueDate     DateTime      @db.Date
  status      InvoiceStatus @default(DRAFT)
  notes       String?       @db.Text

  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}

// ========================
// OPERATIONS & HELPDESK
// ========================

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Ticket {
  id          String         @id @default(cuid())
  title       String
  description String         @db.Text
  category    String         // e.g., IT Support, HR, Maintenance
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)

  authorId    String
  author      EmployeeProfile @relation("TicketAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  assigneeId  String?
  assignee    EmployeeProfile? @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)
}
